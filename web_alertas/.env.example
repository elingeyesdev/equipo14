# Proxy de Vite en desarrollo: URL del backend SIN /api
VITE_API_PROXY=http://127.0.0.1:3000

# Opcional: URL completa de la API (sin proxy)
# VITE_API_URL=http://127.0.0.1:3000/api

# Mapbox — token público (pk.) desde https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.tu_token_mapbox_aqui
