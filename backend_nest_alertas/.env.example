### CONEXION BASE DE DATOS (PostgreSQL + PostGIS) ###

# Una sola vez en la base (psql o pgAdmin), en alertas_db:
# CREATE EXTENSION IF NOT EXISTS postgis;

DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=postgres
DATABASE_PASSWORD=123
DATABASE_NAME=alertas_db

# Opcional: true para ver SQL en consola
DATABASE_LOGGING=false

### SERVIDOR ###

PORT=3000

### CLOUDINARY (subida de imágenes en reportes; valores en tu panel de Cloudinary) ###

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Carpeta opcional en el Media Library (por defecto: alertas)
CLOUDINARY_FOLDER=alertas
